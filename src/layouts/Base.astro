---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  keywords?: string;
  lang: 'pt' | 'en';
  /** Canonical path (e.g. "/" or "/privacidade") */
  canonicalPath?: string;
  ogImage?: string;
}

const {
  title,
  description,
  keywords,
  lang,
  canonicalPath = '/',
  ogImage = '/assets/og-image.png',
} = Astro.props;

const siteUrl = 'https://fofoka.com';
const canonical = `${siteUrl}/${lang}${canonicalPath === '/' ? '' : canonicalPath}`;

// Alternate paths mapping
const altLang = lang === 'pt' ? 'en' : 'pt';
const altPath = canonicalPath; // same path, different locale prefix
const altCanonical = `${siteUrl}/${altLang}${altPath === '/' ? '' : altPath}`;
const defaultCanonical = `${siteUrl}/pt${canonicalPath === '/' ? '' : canonicalPath}`;
---

<!DOCTYPE html>
<html lang={lang} dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0F0F0E" />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="robots" content="index, follow" />

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={lang === 'pt' ? 'pt-BR' : 'en-US'} href={canonical} />
    <link rel="alternate" hreflang={altLang === 'pt' ? 'pt-BR' : 'en-US'} href={altCanonical} />
    <link rel="alternate" hreflang="x-default" href={defaultCanonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:site_name" content="Fofoka" />
    <meta property="og:locale" content={lang === 'pt' ? 'pt_BR' : 'en_US'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/icons/favicon.svg" />
    <link rel="apple-touch-icon" href="/assets/icons/apple-touch-icon.png" />

    <!-- JSON-LD: Organization -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Fofoka",
        "url": "https://fofoka.com",
        "logo": "https://fofoka.com/assets/logos/logo-darkmode.svg",
        "description": "Rede social anônima baseada em geolocalização",
        "contactPoint": {
          "@type": "ContactPoint",
          "email": "contato@fofoka.com",
          "contactType": "customer support"
        }
      }
    </script>
  </head>
  <body>
    <Navbar lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />

    <!-- Scroll reveal -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry, i) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const delay = el.dataset.delay ? parseInt(el.dataset.delay) : 0;
              setTimeout(() => {
                el.classList.add('visible');
              }, delay);
              observer.unobserve(el);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.reveal').forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
