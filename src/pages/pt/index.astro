---
import Base from '../../layouts/Base.astro';
import pt from '../../i18n/pt.json';

const t = pt;
const lang = 'pt' as const;
---

<Base
  title={t.seo.home_title}
  description={t.seo.home_description}
  keywords={t.seo.home_keywords}
  lang={lang}
  canonicalPath="/"
>

<!-- ================================================================
     1. HERO
================================================================ -->
<section class="hero" id="inicio" aria-label="Hero">
  <div class="hero__glow" aria-hidden="true"></div>

  <div class="container hero__inner">
    <div class="hero__pin-wrap" aria-hidden="true">
      <div class="hero__pin-ring"></div>
      <img
        src="/assets/logos/logo-darkmode.svg"
        alt="Fofoka — pin mascarado"
        width="120" height="120"
        class="hero__pin-img"
        loading="eager"
      />
    </div>

    <h1 class="hero__title">
      {t.hero.title_1}<br />
      {t.hero.title_2}<br />
      <em>{t.hero.title_3}</em>
    </h1>

    <p class="hero__subtitle">{t.hero.subtitle}</p>

    <div class="hero__btns" id="download">
      <a href="#" class="store-btn" aria-label={t.hero.app_store}>
        <!-- Apple logo -->
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
        <span class="store-btn__text">
          <span class="store-btn__sub">Download on the</span>
          <span class="store-btn__name">App Store</span>
        </span>
      </a>
      <a href="#" class="store-btn" aria-label={t.hero.google_play}>
        <!-- Play logo -->
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3.18 23.76c.3.17.64.24.99.2l12.6-7.27-2.89-2.89-10.7 9.96zM.5 1.5C.19 1.84 0 2.37 0 3.06v17.88c0 .69.19 1.22.5 1.56l.08.08 10.02-10.02v-.24L.58 1.42.5 1.5zM20.28 10.8l-2.71-1.56-3.2 3.2 3.2 3.2 2.73-1.57c.78-.45.78-1.82-.02-2.27zM4.17.24l12.6 7.27-2.89 2.89L3.18.44A1.2 1.2 0 014.17.24z"/></svg>
        <span class="store-btn__text">
          <span class="store-btn__sub">Get it on</span>
          <span class="store-btn__name">Google Play</span>
        </span>
      </a>
    </div>

    <p class="hero__tagline">{t.hero.tagline}</p>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-dot"></span>
  </div>
</section>

<!-- ================================================================
     2. COMO FUNCIONA
================================================================ -->
<section class="section how" id="como-funciona" aria-labelledby="how-title">
  <div class="container">
    <p class="eyebrow reveal">Como funciona</p>
    <h2 class="section-title reveal" id="how-title">{t.how_it_works.title}</h2>

    <div class="how__grid">
      <!-- Step 1: Localização -->
      <div class="how__card reveal" data-delay="0">
        <div class="how__step">01</div>
        <div class="how__icon how__icon--local">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <h3 class="how__card-title">{t.how_it_works.location.title}</h3>
        <p class="how__card-desc">{t.how_it_works.location.desc}</p>
      </div>

      <!-- Step 2: Anônimo -->
      <div class="how__card reveal" data-delay="100">
        <div class="how__step">02</div>
        <div class="how__icon how__icon--anon">
          <img src="/assets/logos/logo-darkmode.svg" alt="" width="26" height="26" aria-hidden="true" />
        </div>
        <h3 class="how__card-title">{t.how_it_works.anonymous.title}</h3>
        <p class="how__card-desc">{t.how_it_works.anonymous.desc}</p>
      </div>

      <!-- Step 3: Efêmero -->
      <div class="how__card reveal" data-delay="200">
        <div class="how__step">03</div>
        <div class="how__icon how__icon--ephemeral">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <h3 class="how__card-title">{t.how_it_works.ephemeral.title}</h3>
        <p class="how__card-desc">{t.how_it_works.ephemeral.desc}</p>
      </div>
    </div>
  </div>
</section>

<!-- ================================================================
     3. RECURSOS — 6 features zigzag
================================================================ -->
<section class="section features" id="recursos" aria-labelledby="features-title">
  <div class="container">
    <p class="eyebrow reveal">Recursos</p>
    <h2 class="section-title reveal" id="features-title">{t.features.title}</h2>

    <div class="features__list">

      <!-- ── Feature 1: Temperatura ── -->
      <div class="feat reveal">
        <div class="feat__text">
          <span class="feat__number">01</span>
          <h3 class="feat__title">{t.features.temperature.title}</h3>
          <p class="feat__desc">{t.features.temperature.desc}</p>
          <!-- Pins row -->
          <div class="feat__pins">
            <div class="feat__pin-item">
              <img src="/assets/pins/pin-pegando-fogo.svg" alt="pegando fogo" width="28" height="35" />
              <span class="feat__pin-label feat__pin-label--fire">{t.features.temperature.levels.on_fire}</span>
            </div>
            <div class="feat__pin-item">
              <img src="/assets/pins/pin-quente.svg" alt="quente" width="24" height="30" />
              <span class="feat__pin-label feat__pin-label--hot">{t.features.temperature.levels.hot}</span>
            </div>
            <div class="feat__pin-item">
              <img src="/assets/pins/pin-normal.svg" alt="normal" width="20" height="25" />
              <span class="feat__pin-label feat__pin-label--normal">{t.features.temperature.levels.normal}</span>
            </div>
            <div class="feat__pin-item">
              <img src="/assets/pins/pin-fria.svg" alt="fria" width="18" height="22" />
              <span class="feat__pin-label feat__pin-label--cold">{t.features.temperature.levels.cold}</span>
            </div>
          </div>
        </div>
        <!-- Mock: feed card with temperature -->
        <div class="feat__visual" aria-hidden="true">
          <div class="mock mock--feed">
            <div class="mock__bar">
              <div class="mock__dot mock__dot--red"></div>
              <div class="mock__dot mock__dot--yellow"></div>
              <div class="mock__dot mock__dot--green"></div>
            </div>
            <div class="mock__card">
              <div class="mock__card-meta">
                <span class="mock__badge mock__badge--fire">🔥 pegando fogo</span>
                <span class="mock__time">5 min</span>
              </div>
              <p class="mock__text">"Descobri que o gerente do Café Floresta está saindo com a coordenadora de RH 👀"</p>
              <div class="mock__tags">
                <span class="mock__tag">#trabalho</span>
                <span class="mock__tag">#escritório</span>
              </div>
              <div class="mock__actions">
                <div class="mock__action">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                  <span>847</span>
                </div>
                <div class="mock__action">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3H10z"/><path d="M17 2h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>
                  <span>12</span>
                </div>
                <div class="mock__action">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                  <span>93</span>
                </div>
              </div>
            </div>
            <div class="mock__card mock__card--dim">
              <div class="mock__card-meta">
                <span class="mock__badge mock__badge--hot">🌶️ quente</span>
                <span class="mock__time">23 min</span>
              </div>
              <p class="mock__text">"A farmácia da rua 7 está vendendo produto vencido há 3 meses"</p>
              <div class="mock__tags">
                <span class="mock__tag">#vizinhança</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Feature 2: Comentários ── -->
      <div class="feat feat--reverse reveal">
        <!-- Mock: anonymous comment thread -->
        <div class="feat__visual" aria-hidden="true">
          <div class="mock mock--comments">
            <div class="mock__bar">
              <div class="mock__dot mock__dot--red"></div>
              <div class="mock__dot mock__dot--yellow"></div>
              <div class="mock__dot mock__dot--green"></div>
            </div>
            <div class="mock__thread-header">
              <span class="mock__badge mock__badge--fire">🔥 pegando fogo</span>
              <span class="mock__comment-count">93 comentários</span>
            </div>
            <div class="mock__bubble mock__bubble--left">
              <div class="mock__avatar">😱</div>
              <div class="mock__bubble-body">
                <p>eu trabalho ali e confirmo tudo isso kkk</p>
                <div class="mock__bubble-meta"><span>👍 48</span></div>
              </div>
            </div>
            <div class="mock__bubble mock__bubble--right">
              <div class="mock__bubble-body mock__bubble-body--right">
                <p>alguém já reportou pra vigilância sanitária?</p>
                <div class="mock__bubble-meta"><span>👍 31</span></div>
              </div>
              <div class="mock__avatar">🤔</div>
            </div>
            <div class="mock__bubble mock__bubble--left">
              <div class="mock__avatar">👀</div>
              <div class="mock__bubble-body">
                <p>passei lá ontem, tá cheio de gente mesmo</p>
                <div class="mock__bubble-meta"><span>👍 19</span></div>
              </div>
            </div>
            <div class="mock__reply-bar">
              <span class="mock__reply-placeholder">Comentar anonimamente...</span>
              <button class="mock__reply-btn" tabindex="-1">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              </button>
            </div>
          </div>
        </div>
        <div class="feat__text">
          <span class="feat__number">02</span>
          <h3 class="feat__title">{t.features.comments.title}</h3>
          <p class="feat__desc">{t.features.comments.desc}</p>
        </div>
      </div>

      <!-- ── Feature 3: Likes ── -->
      <div class="feat reveal">
        <div class="feat__text">
          <span class="feat__number">03</span>
          <h3 class="feat__title">{t.features.likes.title}</h3>
          <p class="feat__desc">{t.features.likes.desc}</p>
        </div>
        <!-- Mock: reaction bars -->
        <div class="feat__visual" aria-hidden="true">
          <div class="mock mock--likes">
            <div class="mock__bar">
              <div class="mock__dot mock__dot--red"></div>
              <div class="mock__dot mock__dot--yellow"></div>
              <div class="mock__dot mock__dot--green"></div>
            </div>
            <div class="mock__reaction-row">
              <button class="mock__react-btn mock__react-btn--like active" tabindex="-1">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                <span>847</span>
              </button>
              <button class="mock__react-btn" tabindex="-1">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3H10z"/><path d="M17 2h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>
                <span>12</span>
              </button>
            </div>
            <div class="mock__temp-meter">
              <p class="mock__meter-label">Termômetro do bairro</p>
              <div class="mock__meter-bars">
                <div class="mock__meter-item">
                  <span class="mock__meter-emoji">🔥</span>
                  <div class="mock__meter-track"><div class="mock__meter-fill mock__meter-fill--fire" style="width:88%"></div></div>
                  <span class="mock__meter-val">847</span>
                </div>
                <div class="mock__meter-item">
                  <span class="mock__meter-emoji">🌶️</span>
                  <div class="mock__meter-track"><div class="mock__meter-fill mock__meter-fill--hot" style="width:62%"></div></div>
                  <span class="mock__meter-val">312</span>
                </div>
                <div class="mock__meter-item">
                  <span class="mock__meter-emoji">😐</span>
                  <div class="mock__meter-track"><div class="mock__meter-fill mock__meter-fill--normal" style="width:34%"></div></div>
                  <span class="mock__meter-val">89</span>
                </div>
                <div class="mock__meter-item">
                  <span class="mock__meter-emoji">🥶</span>
                  <div class="mock__meter-track"><div class="mock__meter-fill mock__meter-fill--cold" style="width:18%"></div></div>
                  <span class="mock__meter-val">23</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Feature 4: Hashtags ── -->
      <div class="feat feat--reverse reveal">
        <!-- Mock: hashtag cloud -->
        <div class="feat__visual" aria-hidden="true">
          <div class="mock mock--hashtags">
            <div class="mock__bar">
              <div class="mock__dot mock__dot--red"></div>
              <div class="mock__dot mock__dot--yellow"></div>
              <div class="mock__dot mock__dot--green"></div>
            </div>
            <p class="mock__ht-label">Trending no seu bairro</p>
            <div class="mock__ht-cloud">
              <span class="mock__ht mock__ht--lg">#casamento</span>
              <span class="mock__ht mock__ht--md">#trabalho</span>
              <span class="mock__ht mock__ht--sm">#política</span>
              <span class="mock__ht mock__ht--lg">#vizinho</span>
              <span class="mock__ht mock__ht--xl">#escola</span>
              <span class="mock__ht mock__ht--sm">#festa</span>
              <span class="mock__ht mock__ht--md">#bairro</span>
              <span class="mock__ht mock__ht--sm">#trânsito</span>
              <span class="mock__ht mock__ht--lg">#restaurante</span>
              <span class="mock__ht mock__ht--md">#academia</span>
              <span class="mock__ht mock__ht--sm">#condomínio</span>
            </div>
          </div>
        </div>
        <div class="feat__text">
          <span class="feat__number">04</span>
          <h3 class="feat__title">{t.features.hashtags.title}</h3>
          <p class="feat__desc">{t.features.hashtags.desc}</p>
          <div class="feat__tags">
            <span class="feat__tag">#casamento</span>
            <span class="feat__tag">#trabalho</span>
            <span class="feat__tag">#vizinho</span>
            <span class="feat__tag">#bairro</span>
            <span class="feat__tag">#escola</span>
          </div>
        </div>
      </div>

      <!-- ── Feature 5: Emoji como avatar ── -->
      <div class="feat reveal">
        <div class="feat__text">
          <span class="feat__number">05</span>
          <h3 class="feat__title">{t.features.emoji.title}</h3>
          <p class="feat__desc">{t.features.emoji.desc}</p>
        </div>
        <!-- Mock: emoji picker + posts -->
        <div class="feat__visual" aria-hidden="true">
          <div class="mock mock--emoji">
            <div class="mock__bar">
              <div class="mock__dot mock__dot--red"></div>
              <div class="mock__dot mock__dot--yellow"></div>
              <div class="mock__dot mock__dot--green"></div>
            </div>
            <p class="mock__emoji-label">Escolha seu emoji</p>
            <div class="mock__emoji-grid">
              <button class="mock__emo mock__emo--active" tabindex="-1">😱</button>
              <button class="mock__emo" tabindex="-1">🤔</button>
              <button class="mock__emo" tabindex="-1">👀</button>
              <button class="mock__emo" tabindex="-1">😂</button>
              <button class="mock__emo" tabindex="-1">🤫</button>
              <button class="mock__emo" tabindex="-1">😤</button>
              <button class="mock__emo" tabindex="-1">🙈</button>
              <button class="mock__emo" tabindex="-1">🔥</button>
            </div>
            <div class="mock__emoji-posts">
              <div class="mock__epost">
                <div class="mock__epost-avatar" style="background: rgba(232,89,60,0.15)">😱</div>
                <div class="mock__epost-body">
                  <p>"Sabe aquele médico famoso do bairro?"</p>
                  <span class="mock__badge mock__badge--fire">🔥 pegando fogo</span>
                </div>
              </div>
              <div class="mock__epost">
                <div class="mock__epost-avatar" style="background: rgba(245,166,35,0.15)">👀</div>
                <div class="mock__epost-body">
                  <p>"Viram o que aconteceu no prédio do lado?"</p>
                  <span class="mock__badge mock__badge--hot">🌶️ quente</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Feature 6: Mapa ── -->
      <div class="feat feat--reverse reveal">
        <!-- Mock: dark map with pins -->
        <div class="feat__visual" aria-hidden="true">
          <div class="mock mock--map">
            <div class="mock__bar">
              <div class="mock__dot mock__dot--red"></div>
              <div class="mock__dot mock__dot--yellow"></div>
              <div class="mock__dot mock__dot--green"></div>
            </div>
            <div class="mock__map-body">
              <!-- Street grid SVG -->
              <svg class="mock__map-grid" viewBox="0 0 320 220" aria-hidden="true">
                <!-- Blocks -->
                <rect x="10" y="10" width="90" height="60" rx="4" fill="rgba(255,247,240,0.03)"/>
                <rect x="120" y="10" width="80" height="60" rx="4" fill="rgba(255,247,240,0.03)"/>
                <rect x="220" y="10" width="90" height="60" rx="4" fill="rgba(255,247,240,0.03)"/>
                <rect x="10" y="90" width="60" height="70" rx="4" fill="rgba(255,247,240,0.03)"/>
                <rect x="90" y="90" width="110" height="70" rx="4" fill="rgba(255,247,240,0.03)"/>
                <rect x="220" y="90" width="90" height="70" rx="4" fill="rgba(255,247,240,0.03)"/>
                <rect x="10" y="180" width="130" height="30" rx="4" fill="rgba(255,247,240,0.03)"/>
                <rect x="160" y="180" width="150" height="30" rx="4" fill="rgba(255,247,240,0.03)"/>
                <!-- Roads (gaps between blocks) -->
                <line x1="0" y1="80" x2="320" y2="80" stroke="rgba(255,247,240,0.07)" stroke-width="1"/>
                <line x1="0" y1="170" x2="320" y2="170" stroke="rgba(255,247,240,0.07)" stroke-width="1"/>
                <line x1="110" y1="0" x2="110" y2="220" stroke="rgba(255,247,240,0.07)" stroke-width="1"/>
                <line x1="210" y1="0" x2="210" y2="220" stroke="rgba(255,247,240,0.07)" stroke-width="1"/>
              </svg>
              <!-- Pins overlaid -->
              <img class="mock__map-pin mock__map-pin--fire" src="/assets/pins/pin-pegando-fogo.svg" alt="" style="left:52%;top:18%;width:28px" />
              <img class="mock__map-pin" src="/assets/pins/pin-quente.svg" alt="" style="left:18%;top:42%;width:24px" />
              <img class="mock__map-pin" src="/assets/pins/pin-normal.svg" alt="" style="left:72%;top:55%;width:20px" />
              <img class="mock__map-pin" src="/assets/pins/pin-fria.svg" alt="" style="left:35%;top:72%;width:18px" />
              <img class="mock__map-pin" src="/assets/pins/pin-quente.svg" alt="" style="left:82%;top:20%;width:24px" />
              <!-- Tooltip -->
              <div class="mock__map-tooltip">
                <span class="mock__badge mock__badge--fire">🔥</span>
                <span class="mock__tooltip-text">Café Floresta · 847 curtidas</span>
              </div>
            </div>
            <!-- Legend -->
            <div class="mock__map-legend">
              <span class="mock__legend-item"><span class="mock__legend-dot" style="background:#E8593C"></span>pegando fogo</span>
              <span class="mock__legend-item"><span class="mock__legend-dot" style="background:#F5A623"></span>quente</span>
              <span class="mock__legend-item"><span class="mock__legend-dot" style="background:#B5A99A"></span>normal</span>
              <span class="mock__legend-item"><span class="mock__legend-dot" style="background:#6B7AE8"></span>fria</span>
            </div>
          </div>
        </div>
        <div class="feat__text">
          <span class="feat__number">06</span>
          <h3 class="feat__title">{t.features.map.title}</h3>
          <p class="feat__desc">{t.features.map.desc}</p>
        </div>
      </div>

    </div><!-- /features__list -->
  </div>
</section>

<!-- ================================================================
     4. RANKING & CONQUISTAS
================================================================ -->
<section class="section ranking" id="ranking" aria-labelledby="ranking-title">
  <div class="container">
    <p class="eyebrow reveal">Competição</p>
    <h2 class="section-title reveal" id="ranking-title">{t.ranking.title}</h2>
