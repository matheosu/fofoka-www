<style>
/* ==================================================================
   SHARED HELPERS (page-scoped)
================================================================== */
.eyebrow {
  display: block;
  text-align: center;
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--fogo);
  margin-bottom: 12px;
}

.section-sub {
  text-align: center;
  font-size: clamp(15px, 2vw, 17px);
  color: var(--text-2);
  max-width: 540px;
  margin: 12px auto 56px;
  line-height: 1.7;
}

/* store-btn text layout */
.store-btn__text {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  line-height: 1.25;
}
.store-btn__sub  { font-size: 10px; opacity: 0.65; font-weight: 400; }
.store-btn__name { font-size: 15px; font-weight: 600; }

/* ==================================================================
   1. HERO
================================================================== */
.hero {
  position: relative;
  min-height: calc(100svh - 64px);
  display: flex;
  align-items: center;
  overflow: hidden;
}

.hero__glow {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 50% at 50% 20%, rgba(232,89,60,0.13) 0%, transparent 70%);
  pointer-events: none;
}

.hero__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 28px;
  padding-top: 64px;
  padding-bottom: 80px;
  position: relative;
  z-index: 1;
}

/* Pin with floating ring */
.hero__pin-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 160px;
  height: 160px;
}

.hero__pin-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 1px solid rgba(232,89,60,0.2);
  animation: ring-pulse 3s ease-in-out infinite;
}

.hero__pin-ring::before {
  content: '';
  position: absolute;
  inset: 14px;
  border-radius: 50%;
  border: 1px solid rgba(232,89,60,0.12);
}

@keyframes ring-pulse {
  0%, 100% { transform: scale(1);   opacity: 1; }
  50%       { transform: scale(1.06); opacity: 0.6; }
}

.hero__pin-img {
  width: 120px;
  height: 120px;
  animation: float 3s ease-in-out infinite;
  filter: drop-shadow(0 12px 40px rgba(232,89,60,0.4));
  position: relative;
  z-index: 1;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-10px); }
}

.hero__title {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: clamp(32px, 7vw, 52px);
  line-height: 1.12;
  letter-spacing: -0.02em;
  color: var(--text);
}

.hero__title em {
  font-style: normal;
  color: var(--fogo);
}

.hero__subtitle {
  font-size: clamp(15px, 2.2vw, 18px);
  color: var(--text-2);
  max-width: 460px;
  line-height: 1.75;
}

.hero__btns {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: center;
}

.hero__tagline {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--murmur);
  letter-spacing: 5px;
  text-transform: lowercase;
  opacity: 0.7;
}

.hero__scroll {
  position: absolute;
  bottom: 28px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero__scroll-dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--fogo);
  animation: scroll-bob 2s ease-in-out infinite;
  box-shadow: 0 0 8px rgba(232,89,60,0.5);
}

@keyframes scroll-bob {
  0%, 100% { transform: translateY(0); opacity: 1; }
  50%       { transform: translateY(8px); opacity: 0.4; }
}

/* ==================================================================
   2. COMO FUNCIONA
================================================================== */
.how .section-title { margin-bottom: 0; }

.how__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
  margin-top: 48px;
}

@media (min-width: 768px) {
  .how__grid { grid-template-columns: repeat(3, 1fr); }
}

.how__card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 32px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  position: relative;
  transition: border-color var(--transition-base);
}

.how__card:hover { border-color: var(--border-hover); }

.how__step {
  position: absolute;
  top: 24px;
  right: 24px;
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text-3);
  letter-spacing: 1px;
}

.how__icon {
  width: 52px;
  height: 52px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.how__icon--local    { background: rgba(52,152,219,0.12); color: var(--local); }
.how__icon--anon     { background: rgba(232,89,60,0.12); }
.how__icon--ephemeral{ background: rgba(181,169,154,0.12); color: var(--murmur); }

.how__card-title {
  font-family: var(--font-heading);
  font-weight: 600;
  font-size: 18px;
  color: var(--text);
}

.how__card-desc {
  font-size: 14px;
  color: var(--text-2);
  line-height: 1.75;
}

/* ==================================================================
   3. FEATURES
================================================================== */
.features .section-title { margin-bottom: 0; }

.features__list {
  display: flex;
  flex-direction: column;
  gap: 96px;
  margin-top: 72px;
}

/* Feature row */
.feat {
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px;
  align-items: center;
}

@media (min-width: 1024px) {
  .feat { grid-template-columns: 1fr 1fr; gap: 64px; }
  .feat--reverse .feat__text   { order: 2; }
  .feat--reverse .feat__visual { order: 1; }
}

.feat__number {
  display: block;
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 2px;
  color: var(--fogo);
  margin-bottom: 12px;
}

.feat__title {
  font-family: var(--font-heading);
  font-weight: 600;
  font-size: clamp(20px, 3vw, 24px);
  color: var(--text);
  line-height: 1.2;
  margin-bottom: 14px;
}

.feat__desc {
  font-size: clamp(14px, 1.5vw, 16px);
  color: var(--text-2);
  line-height: 1.75;
}

/* Pins row */
.feat__pins {
  display: flex;
  align-items: flex-end;
  gap: 28px;
  margin-top: 28px;
}

.feat__pin-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.feat__pin-label {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.5px;
  text-transform: lowercase;
}

.feat__pin-label--fire   { color: var(--fogo); }
.feat__pin-label--hot    { color: var(--quente); }
.feat__pin-label--normal { color: var(--murmur); }
.feat__pin-label--cold   { color: var(--rank); }

/* Hashtag pills */
.feat__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 20px;
}

.feat__tag {
  padding: 5px 12px;
  border-radius: 10px;
  background: rgba(232,89,60,0.1);
  color: var(--fogo);
  font-size: 12px;
}

/* Visual mock wrapper */
.feat__visual {
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid var(--border);
  background: var(--bg-elevated);
  box-shadow: 0 24px 64px rgba(0,0,0,0.5);
}

/* ==================================================================
   MOCK UI COMPONENTS
================================================================== */
.mock {
  font-family: var(--font-body);
  font-size: 13px;
  color: var(--text);
  display: flex;
  flex-direction: column;
}

/* traffic-light bar */
.mock__bar {
  display: flex;
  gap: 6px;
  align-items: center;
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
  background: rgba(255,247,240,0.02);
}

.mock__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
}

.mock__dot--red    { background: #FF5F57; }
.mock__dot--yellow { background: #FEBC2E; }
.mock__dot--green  { background: #28C840; }

/* ── Feed mock ── */
.mock--feed { gap: 0; }

.mock__card {
  margin: 12px;
  padding: 14px;
  background: rgba(255,247,240,0.03);
  border: 1px solid rgba(255,247,240,0.06);
  border-radius: 14px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.mock__card--dim { opacity: 0.55; }

.mock__card-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.mock__badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 9px;
  border-radius: 20px;
  font-size: 10px;
  font-weight: 500;
}

